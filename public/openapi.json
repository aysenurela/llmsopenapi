{
  "openapi": "3.0.3",
  "info": {
    "title": "Acme SaaS API",
    "version": "1.0.0",
    "description": "RESTful API for plan selection and account onboarding. Each response includes a `nextAction` field that indicates the next endpoint to call, allowing callers to complete the signup funnel sequentially without embedding flow logic on the client.",
    "contact": {
      "name": "Acme SaaS",
      "url": "https://llmsopenapi.vercel.app"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "externalDocs": {
    "description": "Integration guide (llms.txt)",
    "url": "https://llmsopenapi.vercel.app/llms.txt"
  },
  "servers": [
    { "url": "https://llmsopenapi.vercel.app", "description": "Production" },
    { "url": "http://localhost:5173", "description": "Local dev" }
  ],
  "tags": [
    {
      "name": "Onboarding",
      "description": "Sequential funnel: `recommend-plan` → `create-account` → `create-subscription` → (user confirmation) → `create-checkout`. Follow the `nextAction` field in each response to advance to the next step."
    },
    {
      "name": "Utility",
      "description": "Helper endpoints for development and testing."
    }
  ],
  "components": {
    "schemas": {
      "PlanId": {
        "type": "string",
        "enum": ["starter", "pro", "enterprise"],
        "description": "Machine-readable plan identifier. Use the value returned by `/api/recommend-plan` when calling `/api/create-subscription`.",
        "example": "enterprise"
      },
      "HelpfulLinks": {
        "type": "object",
        "description": "Links included in every response to help users continue the signup flow.",
        "properties": {
          "plansUrl": {
            "type": "string",
            "format": "uri",
            "description": "URL of the plans page.",
            "example": "https://llmsopenapi.vercel.app/features"
          },
          "signupUrl": {
            "type": "string",
            "format": "uri",
            "description": "URL of the signup form.",
            "example": "https://llmsopenapi.vercel.app/signup"
          }
        }
      },
      "Plan": {
        "type": "object",
        "description": "A single available plan with pricing.",
        "required": ["planId", "name", "description", "maxEmployees", "supportsSSO", "price", "currency", "billingCycle"],
        "properties": {
          "planId": { "$ref": "#/components/schemas/PlanId" },
          "name": { "type": "string", "description": "Human-readable plan name.", "example": "Enterprise" },
          "description": { "type": "string", "description": "Short description of the plan.", "example": "For large teams with advanced needs including SSO." },
          "maxEmployees": {
            "oneOf": [{ "type": "integer", "minimum": 1 }, { "type": "string", "enum": ["unlimited"] }],
            "description": "Maximum number of employees. `\"unlimited\"` for Enterprise.",
            "example": 10
          },
          "supportsSSO": { "type": "boolean", "description": "Whether SSO is available on this plan.", "example": false },
          "price": { "type": "integer", "description": "Price in minor currency units.", "minimum": 0, "example": 3900 },
          "currency": { "type": "string", "minLength": 3, "maxLength": 3, "description": "ISO 4217 currency code.", "example": "USD" },
          "billingCycle": { "type": "string", "enum": ["monthly", "annual"], "example": "monthly" }
        }
      },
      "NextAction": {
        "type": "string",
        "enum": ["create_account", "create_subscription", "confirm_checkout", "completed"],
        "description": "Identifier of the next operation in the onboarding funnel. Follow this field instead of hard-coding flow logic.",
        "example": "create_account"
      },
      "Error": {
        "type": "object",
        "description": "Standard error envelope returned on all 4xx and 5xx responses. Always includes `plansUrl` and `signupUrl` so the caller can direct the user to continue.",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "string",
            "description": "Human-readable description of what went wrong.",
            "example": "`employees` must be a positive number."
          },
          "plansUrl": { "type": "string", "format": "uri", "example": "https://llmsopenapi.vercel.app/features" },
          "signupUrl": { "type": "string", "format": "uri", "example": "https://llmsopenapi.vercel.app/signup" }
        },
        "example": {
          "error": "`employees` must be a positive number.",
          "plansUrl": "https://llmsopenapi.vercel.app/features",
          "signupUrl": "https://llmsopenapi.vercel.app/signup"
        }
      },
      "PlanRecommendation": {
        "type": "object",
        "description": "Recommended plan with localized pricing and the reasoning behind the selection.",
        "required": ["recommendedPlan", "planId", "price", "currency", "billingCycle", "reasons", "nextAction"],
        "properties": {
          "recommendedPlan": {
            "type": "string",
            "description": "Human-readable plan name.",
            "example": "Enterprise"
          },
          "planId": {
            "$ref": "#/components/schemas/PlanId"
          },
          "price": {
            "type": "integer",
            "description": "Price in minor currency units (e.g. cents for USD, colones for CRC).",
            "minimum": 0,
            "example": 149900
          },
          "currency": {
            "type": "string",
            "description": "ISO 4217 currency code, derived from the `country` input.",
            "minLength": 3,
            "maxLength": 3,
            "example": "CRC"
          },
          "billingCycle": {
            "type": "string",
            "description": "Billing frequency.",
            "enum": ["monthly", "annual"],
            "example": "monthly"
          },
          "reasons": {
            "type": "array",
            "description": "Ordered list of human-readable reasons explaining why this plan was selected.",
            "items": { "type": "string" },
            "minItems": 1,
            "example": [
              "SSO required — only Enterprise supports SSO",
              "15 employees exceeds Starter limit of 10"
            ]
          },
          "nextAction": {
            "$ref": "#/components/schemas/NextAction"
          },
          "signupUrl": {
            "type": "string",
            "format": "uri",
            "description": "Direct link to the signup form to begin account creation.",
            "example": "https://llmsopenapi.vercel.app/signup"
          },
          "plansUrl": {
            "type": "string",
            "format": "uri",
            "description": "Link to the plans page for human review.",
            "example": "https://llmsopenapi.vercel.app/features"
          }
        }
      },
      "Account": {
        "type": "object",
        "description": "Newly created account record.",
        "required": ["accountId", "email", "company", "createdAt", "nextAction"],
        "properties": {
          "accountId": {
            "type": "string",
            "format": "uuid",
            "description": "Unique account identifier. Pass this value to `/api/create-subscription`.",
            "example": "3fa85f64-5717-4562-b3fc-2c963f66afa6"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Registered email address.",
            "example": "jane@acme.com"
          },
          "company": {
            "type": "string",
            "description": "Company name associated with the account.",
            "example": "Acme Corp"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of account creation.",
            "example": "2026-07-05T14:00:00.000Z"
          },
          "nextAction": {
            "$ref": "#/components/schemas/NextAction"
          }
        }
      },
      "Subscription": {
        "type": "object",
        "description": "Newly created subscription in `pending` state. The caller must present the order summary to the user and obtain explicit confirmation before proceeding to `/api/create-checkout`.",
        "required": ["subscriptionId", "accountId", "plan", "price", "currency", "billingCycle", "status", "nextAction"],
        "properties": {
          "subscriptionId": {
            "type": "string",
            "format": "uuid",
            "description": "Unique subscription identifier. Pass this value to `/api/create-checkout`.",
            "example": "7c9e6679-7425-40de-944b-e07fc1f90ae7"
          },
          "accountId": {
            "type": "string",
            "format": "uuid",
            "description": "The account this subscription is linked to.",
            "example": "3fa85f64-5717-4562-b3fc-2c963f66afa6"
          },
          "plan": {
            "type": "string",
            "description": "Human-readable plan name.",
            "example": "Enterprise"
          },
          "price": {
            "type": "integer",
            "description": "Price in USD cents.",
            "minimum": 0,
            "example": 14900
          },
          "currency": {
            "type": "string",
            "description": "ISO 4217 currency code.",
            "minLength": 3,
            "maxLength": 3,
            "example": "USD"
          },
          "billingCycle": {
            "type": "string",
            "description": "Billing frequency.",
            "enum": ["monthly", "annual"],
            "example": "monthly"
          },
          "status": {
            "type": "string",
            "description": "Subscription lifecycle state.",
            "enum": ["pending", "active"],
            "example": "pending"
          },
          "nextAction": {
            "$ref": "#/components/schemas/NextAction"
          },
          "agentNote": {
            "type": "string",
            "description": "Instruction that must be presented to the user before proceeding. Present this verbatim and wait for explicit approval.",
            "example": "Present the order summary to the user and wait for explicit confirmation before calling /api/create-checkout."
          }
        }
      },
      "Checkout": {
        "type": "object",
        "description": "Activated subscription with a payment redirect URL.",
        "required": ["checkoutUrl", "subscriptionId", "status", "nextAction"],
        "properties": {
          "checkoutUrl": {
            "type": "string",
            "format": "uri",
            "description": "URL to redirect the user to in order to complete payment.",
            "example": "https://checkout.example.com/pay/abc123"
          },
          "subscriptionId": {
            "type": "string",
            "format": "uuid",
            "description": "The subscription that was activated.",
            "example": "7c9e6679-7425-40de-944b-e07fc1f90ae7"
          },
          "status": {
            "type": "string",
            "description": "Subscription status after checkout creation.",
            "enum": ["active"],
            "example": "active"
          },
          "nextAction": {
            "$ref": "#/components/schemas/NextAction"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "The request body is missing required fields or contains invalid values.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" },
            "example": { "error": "`employees` must be a positive number." }
          }
        }
      },
      "NotFound": {
        "description": "The referenced resource (account, subscription) does not exist.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" },
            "example": { "error": "Account not found." }
          }
        }
      },
      "MethodNotAllowed": {
        "description": "HTTP method not supported on this endpoint. `/api/plans` accepts GET; `/api/recommend-plan` accepts GET and POST; other onboarding endpoints require POST; the reset endpoint requires DELETE.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" },
            "example": { "error": "Method not allowed." }
          }
        }
      },
      "InternalServerError": {
        "description": "An unexpected server-side error occurred.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" },
            "example": { "error": "Internal server error." }
          }
        }
      }
    }
  },
  "paths": {
    "/api/pricing": {
      "get": {
        "operationId": "getPricing",
        "summary": "Get pricing for all products",
        "description": "Returns the product catalogue with display names matching the /features page. Each product has a `prices` array with one entry per supported country. Pass `country` to flag the relevant price as `is_default: true`. Use `planId` from each product when calling `/api/create-subscription`.",
        "tags": ["Onboarding"],
        "parameters": [
          {
            "name": "country",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "ISO country code (e.g. `CR`). Marks the matching price entry `is_default: true`.",
            "example": "CR"
          },
          {
            "name": "employees",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 1 },
            "description": "Number of employees. When provided alongside `needsSSO`, the matching product is flagged `is_recommended: true`.",
            "example": 4
          },
          {
            "name": "needsSSO",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean" },
            "description": "Whether SSO is required. Used together with `employees` to flag the best-fit product.",
            "example": true
          }
        ],
        "responses": {
          "200": {
            "description": "Product catalogue",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "products": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "sku":    { "type": "string", "example": "team-ui-advantage" },
                          "name":   { "type": "string", "example": "Team UI Advantage" },
                          "active": { "type": "boolean" },
                          "planId":         { "$ref": "#/components/schemas/PlanId" },
                          "is_recommended": { "type": "boolean", "description": "Present only when `employees` is passed. `true` on the product that best fits the given criteria." },
                          "prices": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "country":        { "type": "string", "example": "US" },
                                "currency":       { "type": "string", "example": "usd" },
                                "unit_amount":    { "type": "integer", "description": "Price in minor currency units (cents)", "example": 3900 },
                                "billing_scheme": { "type": "string", "example": "per_unit" },
                                "type":           { "type": "string", "example": "recurring" },
                                "is_default":     { "type": "boolean" }
                              }
                            }
                          }
                        }
                      }
                    },
                    "plansUrl":  { "type": "string", "format": "uri" },
                    "signupUrl": { "type": "string", "format": "uri" }
                  }
                },
                "example": {
                  "products": [
                    {
                      "sku": "team-ui-advantage", "name": "Team UI Advantage", "active": true, "planId": "starter",
                      "prices": [
                        { "country": "US", "currency": "usd", "unit_amount": 3900,  "billing_scheme": "per_unit", "type": "recurring", "is_default": true  },
                        { "country": "CR", "currency": "crc", "unit_amount": 20900, "billing_scheme": "per_unit", "type": "recurring", "is_default": false }
                      ]
                    },
                    {
                      "sku": "team-ui-premier", "name": "Team UI Premier", "active": true, "planId": "pro",
                      "prices": [
                        { "country": "US", "currency": "usd", "unit_amount": 7900,  "billing_scheme": "per_unit", "type": "recurring", "is_default": true  },
                        { "country": "CR", "currency": "crc", "unit_amount": 41900, "billing_scheme": "per_unit", "type": "recurring", "is_default": false }
                      ]
                    },
                    {
                      "sku": "team-ui-enterprise", "name": "Team UI Enterprise", "active": true, "planId": "enterprise",
                      "prices": [
                        { "country": "US", "currency": "usd", "unit_amount": 14900,  "billing_scheme": "per_unit", "type": "recurring", "is_default": true  },
                        { "country": "CR", "currency": "crc", "unit_amount": 149900, "billing_scheme": "per_unit", "type": "recurring", "is_default": false }
                      ]
                    }
                  ],
                  "plansUrl":  "https://llmsopenapi.vercel.app/features",
                  "signupUrl": "https://llmsopenapi.vercel.app/signup"
                }
              }
            }
          }
        }
      }
    },
    "/api/plans": {
      "get": {
        "operationId": "listPlans",
        "summary": "List all plans",
        "description": "Returns all available plans with pricing. Use this for discovery — e.g. showing a user their options before asking for company details. Pass `country` as a query parameter to get localised pricing. Includes `signupUrl` and `plansUrl` in the response.",
        "tags": ["Onboarding"],
        "parameters": [
          {
            "name": "country",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "minLength": 2, "maxLength": 3, "example": "CR" },
            "description": "ISO 3166-1 alpha-2 or alpha-3 country code. Determines response currency. Defaults to USD if omitted."
          }
        ],
        "responses": {
          "200": {
            "description": "All available plans with pricing.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["plans", "signupUrl", "plansUrl"],
                  "properties": {
                    "plans": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Plan" }
                    },
                    "signupUrl": { "type": "string", "format": "uri", "example": "https://llmsopenapi.vercel.app/signup" },
                    "plansUrl": { "type": "string", "format": "uri", "example": "https://llmsopenapi.vercel.app/features" }
                  }
                },
                "example": {
                  "plans": [
                    { "planId": "starter", "name": "Starter", "description": "For small teams getting started.", "maxEmployees": 10, "supportsSSO": false, "price": 3900, "currency": "USD", "billingCycle": "monthly" },
                    { "planId": "pro", "name": "Pro", "description": "For growing teams that need more capacity.", "maxEmployees": 50, "supportsSSO": false, "price": 7900, "currency": "USD", "billingCycle": "monthly" },
                    { "planId": "enterprise", "name": "Enterprise", "description": "For large teams with advanced needs including SSO.", "maxEmployees": "unlimited", "supportsSSO": true, "price": 14900, "currency": "USD", "billingCycle": "monthly" }
                  ],
                  "signupUrl": "https://llmsopenapi.vercel.app/signup",
                  "plansUrl": "https://llmsopenapi.vercel.app/features"
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/api/recommend-plan": {
      "get": {
        "operationId": "recommendPlanGet",
        "summary": "Recommend a plan (GET)",
        "description": "Same logic as the POST variant but accepts query parameters instead of a request body. Use this from any LLM tool with GET-only browsing. Returns the best-fit plan with localized pricing and a `signupUrl` for the user to continue.",
        "tags": ["Onboarding"],
        "parameters": [
          {
            "name": "employees",
            "in": "query",
            "required": true,
            "schema": { "type": "integer", "minimum": 1, "example": 15 },
            "description": "Number of employees who will use the platform."
          },
          {
            "name": "country",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "minLength": 2, "maxLength": 3, "example": "CR" },
            "description": "ISO 3166-1 country code. Determines response currency."
          },
          {
            "name": "needsSSO",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean", "default": false, "example": true },
            "description": "Pass `true` if SSO is required. Forces Enterprise plan."
          }
        ],
        "responses": {
          "200": {
            "description": "Plan recommendation with localized pricing and signup link.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PlanRecommendation" },
                "example": {
                  "recommendedPlan": "Enterprise",
                  "planId": "enterprise",
                  "price": 149900,
                  "currency": "CRC",
                  "billingCycle": "monthly",
                  "reasons": ["SSO required — only Enterprise supports SSO"],
                  "signupUrl": "https://llmsopenapi.vercel.app/signup",
                  "plansUrl": "https://llmsopenapi.vercel.app/features",
                  "nextAction": "create_account"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      },
      "post": {
        "operationId": "recommendPlan",
        "summary": "Recommend a plan",
        "description": "Call this first — before any other onboarding endpoint. Submit a company profile to receive the best-fit plan with localized pricing. The `planId` and pricing in the response are the inputs for subsequent steps; do not hard-code plan names or prices. Returns `nextAction: \"create_account\"`.",
        "tags": ["Onboarding"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["employees"],
                "properties": {
                  "country": {
                    "type": "string",
                    "description": "ISO 3166-1 alpha-2 country code. Determines the response currency. Defaults to USD if omitted or unrecognised.",
                    "minLength": 2,
                    "maxLength": 2,
                    "example": "CR"
                  },
                  "employees": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "Number of employees who will use the platform. Determines the minimum eligible plan tier.",
                    "example": 15
                  },
                  "needsSSO": {
                    "type": "boolean",
                    "default": false,
                    "description": "Whether Single Sign-On (SSO) is required. When `true`, the Enterprise plan is always recommended regardless of employee count.",
                    "example": true
                  }
                }
              },
              "example": { "country": "CR", "employees": 15, "needsSSO": true }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Plan recommendation with localized pricing.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PlanRecommendation" },
                "example": {
                  "recommendedPlan": "Enterprise",
                  "planId": "enterprise",
                  "price": 149900,
                  "currency": "CRC",
                  "billingCycle": "monthly",
                  "reasons": [
                    "SSO required — only Enterprise supports SSO",
                    "15 employees exceeds Starter limit of 10"
                  ],
                  "signupUrl": "https://llmsopenapi.vercel.app/signup",
                  "plansUrl": "https://llmsopenapi.vercel.app/features",
                  "nextAction": "create_account"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "405": { "$ref": "#/components/responses/MethodNotAllowed" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/api/create-account": {
      "post": {
        "operationId": "createAccount",
        "summary": "Create an account",
        "description": "Step 2. Register a new user account. Returns an `accountId` and `nextAction: \"create_subscription\"`. Returns HTTP 409 with the existing `accountId` if the email is already registered.",
        "tags": ["Onboarding"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "name", "company"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Contact email address. Must be unique — used as the account identifier.",
                    "example": "jane@acme.com"
                  },
                  "name": {
                    "type": "string",
                    "description": "Full name of the primary contact.",
                    "minLength": 1,
                    "example": "Jane Smith"
                  },
                  "company": {
                    "type": "string",
                    "description": "Company or organisation name.",
                    "minLength": 1,
                    "example": "Acme Corp"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Account created successfully.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Account" },
                "example": {
                  "accountId": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
                  "email": "jane@acme.com",
                  "company": "Acme Corp",
                  "createdAt": "2026-07-05T14:00:00.000Z",
                  "nextAction": "create_subscription"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "405": { "$ref": "#/components/responses/MethodNotAllowed" },
          "409": {
            "description": "An account with this email already exists. The existing `accountId` is returned so the caller can continue the flow without creating a duplicate.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/Error" },
                    {
                      "type": "object",
                      "required": ["accountId"],
                      "properties": {
                        "accountId": {
                          "type": "string",
                          "format": "uuid",
                          "description": "ID of the existing account. Use this to proceed to `/api/create-subscription`.",
                          "example": "3fa85f64-5717-4562-b3fc-2c963f66afa6"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/api/create-subscription": {
      "post": {
        "operationId": "createSubscription",
        "summary": "Create a subscription",
        "description": "Step 3. Link an account to a plan. Returns a `subscriptionId`, full order summary, and `nextAction: \"confirm_checkout\"`. **The caller must present the order summary to the user and obtain explicit confirmation before calling `/api/create-checkout`.**",
        "tags": ["Onboarding"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["accountId", "planId"],
                "properties": {
                  "accountId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Account ID returned by `/api/create-account`.",
                    "example": "3fa85f64-5717-4562-b3fc-2c963f66afa6"
                  },
                  "planId": {
                    "$ref": "#/components/schemas/PlanId"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Subscription created in `pending` state. Present the order summary to the user before proceeding.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Subscription" },
                "example": {
                  "subscriptionId": "7c9e6679-7425-40de-944b-e07fc1f90ae7",
                  "accountId": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
                  "plan": "Enterprise",
                  "price": 14900,
                  "currency": "USD",
                  "billingCycle": "monthly",
                  "status": "pending",
                  "nextAction": "confirm_checkout",
                  "agentNote": "Present the order summary to the user and wait for explicit confirmation before calling /api/create-checkout."
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "405": { "$ref": "#/components/responses/MethodNotAllowed" },
          "409": {
            "description": "A pending subscription already exists for this account. The existing `subscriptionId` is returned so the caller can proceed directly to confirmation.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/Error" },
                    {
                      "type": "object",
                      "required": ["subscriptionId", "nextAction"],
                      "properties": {
                        "subscriptionId": {
                          "type": "string",
                          "format": "uuid",
                          "description": "ID of the existing pending subscription.",
                          "example": "7c9e6679-7425-40de-944b-e07fc1f90ae7"
                        },
                        "nextAction": {
                          "$ref": "#/components/schemas/NextAction"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/api/create-checkout": {
      "post": {
        "operationId": "createCheckout",
        "summary": "Create checkout",
        "description": "Step 5 (after user confirmation). Activates the subscription and returns a payment URL. **`confirmed` must be `true`. This flag must not be set until the user has explicitly approved the order summary returned by `/api/create-subscription`. Setting it without user consent is not permitted.**",
        "tags": ["Onboarding"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["subscriptionId", "confirmed"],
                "properties": {
                  "subscriptionId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Subscription ID returned by `/api/create-subscription`.",
                    "example": "7c9e6679-7425-40de-944b-e07fc1f90ae7"
                  },
                  "confirmed": {
                    "type": "boolean",
                    "enum": [true],
                    "description": "Must be `true`. Set only after the user has explicitly confirmed the order summary. Do not infer or assume confirmation.",
                    "example": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Checkout created. Redirect the user to `checkoutUrl` to complete payment.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Checkout" },
                "example": {
                  "checkoutUrl": "https://checkout.example.com/pay/abc123",
                  "subscriptionId": "7c9e6679-7425-40de-944b-e07fc1f90ae7",
                  "status": "active",
                  "nextAction": "completed"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "405": { "$ref": "#/components/responses/MethodNotAllowed" },
          "409": {
            "description": "A checkout already exists for this subscription. The existing `checkoutUrl` is returned.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/Error" },
                    {
                      "type": "object",
                      "required": ["checkoutUrl"],
                      "properties": {
                        "checkoutUrl": {
                          "type": "string",
                          "format": "uri",
                          "description": "URL of the existing checkout session.",
                          "example": "https://checkout.example.com/pay/abc123"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/api/reset": {
      "delete": {
        "operationId": "resetData",
        "summary": "Reset all data",
        "description": "Call before each test run or demo session to start from a clean state. Wipes all accounts, subscriptions, and checkouts from the in-memory store. Do not call during an active onboarding flow — all in-progress data will be lost. Intended for development and demo use only.",
        "tags": ["Utility"],
        "responses": {
          "200": {
            "description": "All data cleared.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["message"],
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "All data cleared."
                    }
                  }
                }
              }
            }
          },
          "405": { "$ref": "#/components/responses/MethodNotAllowed" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    }
  }
}
